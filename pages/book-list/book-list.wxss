.back-btn {
  padding: 20rpx;
  background-color: white;
  margin-bottom: 20rpx;
  color: #1AAD19;
  font-size: 28rpx;
}

.search-bar {
  padding: 20rpx;
  background-color: white;
  margin-bottom: 20rpx;
}

.search-input {
  width: 100%;
  height: 70rpx;
  padding: 0 20rpx;
  background-color: #f5f5f5;
  border-radius: 35rpx;
  font-size: 28rpx;
}

.filter-tabs {
  display: flex;
  background-color: white;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  margin: 0 10rpx;
}

.tab-item.active {
  background-color: #1AAD19;
  color: white;
}

.book-list {
  padding: 0 20rpx;
}

.book-card {
  display: flex;
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.book-cover-wrapper {
  width: 140rpx;
  height: 200rpx;
  margin-right: 20rpx;
  position: relative;
}

.book-cover {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  object-fit: cover;
}

.book-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: white;
}

.badge-available {
  background-color: #07C160;
}

.badge-borrowed {
  background-color: #FA9D3B;
}

.book-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.book-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-author,
.book-isbn,
.book-location {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}
