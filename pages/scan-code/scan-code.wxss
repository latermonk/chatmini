.scan-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.scan-box {
  width: 500rpx;
  height: 500rpx;
  border: 4rpx solid #1AAD19;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}

.scan-line {
  position: absolute;
  width: 100%;
  height: 4rpx;
  background: linear-gradient(to right, transparent, #1AAD19, transparent);
  animation: scan 2s linear infinite;
}

@keyframes scan {
  0% {
    top: 0;
  }
  50% {
    top: 100%;
  }
  100% {
    top: 0;
  }
}

.scan-tip {
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

.result-area {
  margin-top: 40rpx;
}

.result-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-label {
  width: 150rpx;
  font-size: 28rpx;
  color: #999;
}

.result-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.scan-btn {
  margin: 40rpx 20rpx;
}

button {
  margin-top: 20rpx;
}
