page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background-color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.btn-primary {
  background-color: #1AAD19;
  color: white;
}

.btn-success {
  background-color: #07C160;
  color: white;
}

.btn-warning {
  background-color: #FA9D3B;
  color: white;
}

.btn-danger {
  background-color: #E64340;
  color: white;
}

.status-available {
  color: #07C160;
  font-weight: bold;
}

.status-borrowed {
  color: #FA9D3B;
  font-weight: bold;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 100rpx 0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  color: #666;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.book-cover {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
  border-radius: 8rpx;
}
